<Window x:Class="OneThing90.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OneThing90"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource WindowBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#202020" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#181818" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#252526" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3E3E42" />
        <SolidColorBrush x:Key="ButtonPressedBrush" Color="#242426" />
        <SolidColorBrush x:Key="LineBrush" Color="#3F3F46" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#C7C7C7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0D9488" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="PrimarySoftBrush" Color="#162E2B" />
        <SolidColorBrush x:Key="BannerBrush" Color="#332A19" />
        <SolidColorBrush x:Key="BannerLineBrush" Color="#8A621D" />
        <SolidColorBrush x:Key="BannerTitleBrush" Color="#FFE8B0" />
        <SolidColorBrush x:Key="BannerTextBrush" Color="#F8D99C" />
        <SolidColorBrush x:Key="CalendarEmptyBrush" Color="#303036" />
        <SolidColorBrush x:Key="CalendarFutureBrush" Color="#2A2A2F" />
        <SolidColorBrush x:Key="CalendarCompleteBrush" Color="#16A34A" />
        <SolidColorBrush x:Key="CalendarCompleteLineBrush" Color="#86EFAC" />
        <SolidColorBrush x:Key="CalendarTodayBrush" Color="#B45309" />
        <SolidColorBrush x:Key="CalendarTodayLineBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="CalendarPartialBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="CalendarPartialLineBrush" Color="#C4B5FD" />
        <SolidColorBrush x:Key="CalendarMissedBrush" Color="#3A2028" />
        <SolidColorBrush x:Key="CalendarMissedLineBrush" Color="#FB7185" />
        <Thickness x:Key="SectionPadding">20</Thickness>
        <Thickness x:Key="ControlPadding">14,9</Thickness>
        <Thickness x:Key="NavPadding">16,10</Thickness>
        <sys:Double x:Key="TimerFontSize" xmlns:sys="clr-namespace:System;assembly=mscorlib">64</sys:Double>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SectionPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="{DynamicResource SectionPadding}" />
        </Style>

        <Style x:Key="HeroPanel" TargetType="Border" BasedOn="{StaticResource SectionPanel}">
            <Setter Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style x:Key="NavIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="Width" Value="24" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="NavText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,12,0,5" />
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#1F1F1F" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{DynamicResource ControlPadding}" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="QuickButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SwatchButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="Height" Value="8" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource WindowBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TabStripPlacement" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="264" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{DynamicResource SidebarBrush}"
                                    BorderBrush="{DynamicResource LineBrush}"
                                    BorderThickness="0,0,1,0">
                                <DockPanel LastChildFill="True" Margin="18,18,14,18">
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image Source="Assets/OneThing90.png"
                                               Width="44"
                                               Height="44"
                                               Stretch="UniformToFill"
                                               SnapsToDevicePixels="True" />
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="OneThing90"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="90 минут. 90 дней. 1 дело."
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="12"
                                                   Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <Border DockPanel.Dock="Bottom"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Быстрый вид"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <UniformGrid Columns="3" Margin="0,0,0,8">
                                                <Button Content="Сист"
                                                        Command="{Binding SetThemeCommand}"
                                                        CommandParameter="System"
                                                        Style="{StaticResource QuickButton}"
                                                        Margin="0,0,4,0" />
                                                <Button Content="Тем"
                                                        Command="{Binding SetThemeCommand}"
                                                        CommandParameter="Dark"
                                                        Style="{StaticResource QuickButton}"
                                                        Margin="0,0,4,0" />
                                                <Button Content="Свет"
                                                        Command="{Binding SetThemeCommand}"
                                                        CommandParameter="Light"
                                                        Style="{StaticResource QuickButton}" />
                                            </UniformGrid>
                                            <WrapPanel>
                                                <Button ToolTip="Бирюзовый"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Teal"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#0D9488"
                                                        Margin="0,0,6,6" />
                                                <Button ToolTip="Синий"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Blue"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#2563EB"
                                                        Margin="0,0,6,6" />
                                                <Button ToolTip="Зеленый"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Green"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#16A34A"
                                                        Margin="0,0,6,6" />
                                                <Button ToolTip="Фиолетовый"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Violet"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#7C3AED"
                                                        Margin="0,0,6,6" />
                                                <Button ToolTip="Янтарный"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Amber"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#D97706"
                                                        Margin="0,0,6,6" />
                                                <Button ToolTip="Розовый"
                                                        Command="{Binding SetAccentCommand}"
                                                        CommandParameter="Rose"
                                                        Style="{StaticResource SwatchButton}"
                                                        Background="#E11D48"
                                                        Margin="0,0,0,6" />
                                            </WrapPanel>
                                            <Button Content="Свои цвета"
                                                    Command="{Binding SetAccentCommand}"
                                                    CommandParameter="Custom"
                                                    Style="{StaticResource QuickButton}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <TabPanel IsItemsHost="True"
                                              KeyboardNavigation.TabNavigation="Once"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Top" />
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Background="{DynamicResource WindowBrush}">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="{DynamicResource NavPadding}" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Width" Value="226" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Width="{TemplateBinding Width}"
                              MinHeight="{TemplateBinding MinHeight}"
                              Margin="{TemplateBinding Margin}"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="AccentBar"
                                    Width="4"
                                    CornerRadius="2"
                                    Background="Transparent" />
                            <Border x:Name="NavRoot"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    CornerRadius="5"
                                    MinHeight="{TemplateBinding MinHeight}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavRoot" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavRoot" Property="Background" Value="{DynamicResource PrimarySoftBrush}" />
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DayCellBorder" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource CalendarEmptyBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Complete">
                    <Setter Property="Background" Value="{DynamicResource CalendarCompleteBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CalendarCompleteLineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Today">
                    <Setter Property="Background" Value="{DynamicResource CalendarTodayBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CalendarTodayLineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="PartialToday">
                    <Setter Property="Background" Value="{DynamicResource CalendarTodayBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CalendarTodayLineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Partial">
                    <Setter Property="Background" Value="{DynamicResource CalendarPartialBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CalendarPartialLineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Missed">
                    <Setter Property="Background" Value="{DynamicResource CalendarMissedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource CalendarMissedLineBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Future">
                    <Setter Property="Background" Value="{DynamicResource CalendarFutureBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Visibility="{Binding BannerVisibility}"
                Background="{DynamicResource BannerBrush}"
                BorderBrush="{DynamicResource BannerLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding BannerTitle}"
                               Foreground="{DynamicResource BannerTitleBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding BannerMessage}"
                               Foreground="{DynamicResource BannerTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Button Content="Начать 90"
                            Command="{Binding StartFocusCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Отложить 15"
                            Command="{Binding Snooze15Command}"
                            Style="{StaticResource BaseButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Скрыть"
                            Command="{Binding DismissBannerCommand}"
                            Style="{StaticResource GhostButton}" />
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE80F;" Style="{StaticResource NavIcon}" />
                        <TextBlock Text="Сегодня" Style="{StaticResource NavText}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Сегодня" Style="{StaticResource PageTitle}" />
                            <Border Grid.Column="1"
                                    Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding PlanDayText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource SectionPanel}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ThingName}"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontSize="23"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TodayStatusText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,20" />

                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Сегодня" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding TodayMinutesText}" Style="{StaticResource MetricValue}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Серия" Style="{StaticResource MetricLabel}" />
                                            <TextBlock Text="{Binding StreakText}" Style="{StaticResource MetricValue}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding ReminderStatusText}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,20" />

                                    <Button Content="Начать 90-минутный блок"
                                            Command="{Binding StartFocusCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="0,0,0,8" />
                                    <Button Content="Начать 15-минутное спасение"
                                            Command="{Binding StartRescueCommand}"
                                            Style="{StaticResource BaseButton}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource HeroPanel}">
                                <StackPanel>
                                    <TextBlock Text="Таймер" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="{Binding TimerDisplay}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="{DynamicResource TimerFontSize}"
                                               FontWeight="SemiBold"
                                               Margin="0,18,0,0" />
                                    <TextBlock Text="{Binding TimerSubtitle}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               MinHeight="38" />
                                    <ProgressBar Value="{Binding TimerProgress, Mode=OneWay}"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Margin="0,20,0,18" />
                                    <WrapPanel>
                                        <Button Content="{Binding PauseButtonText}"
                                                Command="{Binding PauseResumeCommand}"
                                                Style="{StaticResource BaseButton}"
                                                Width="132"
                                                Margin="0,0,8,8" />
                                        <Button Content="Записать сейчас"
                                                Command="{Binding FinishCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Width="160"
                                                Margin="0,0,8,8" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE787;" Style="{StaticResource NavIcon}" />
                        <TextBlock Text="Путь 90 дней" Style="{StaticResource NavText}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28">
                        <TextBlock Text="Путь 90 дней" Style="{StaticResource PageTitle}" />
                        <Border Style="{StaticResource SectionPanel}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Why}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,18" />

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Закрыто" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding DaysCompletedText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Осталось" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding DaysRemainingText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Прогресс" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding PlanProgress, StringFormat={}{0:0}%}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                </Grid>

                                <ProgressBar Value="{Binding PlanProgress, Mode=OneWay}"
                                             Minimum="0"
                                             Maximum="100"
                                             Margin="0,0,0,20" />

                                <ItemsControl ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="10" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DayCellBorder}"
                                                    ToolTip="{Binding ToolTip}">
                                                <TextBlock Text="{Binding Number}"
                                                           Foreground="White"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <WrapPanel Margin="0,18,0,0">
                                    <TextBlock Text="Зеленый - закрыто"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,0,18,0" />
                                    <TextBlock Text="Желтый - сегодня"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,0,18,0" />
                                    <TextBlock Text="Розовый - пропуск"
                                               Style="{StaticResource MutedText}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" Style="{StaticResource NavIcon}" />
                        <TextBlock Text="Дело" Style="{StaticResource NavText}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28" MaxWidth="760" HorizontalAlignment="Left">
                        <TextBlock Text="Главное дело" Style="{StaticResource PageTitle}" />
                        <Border Style="{StaticResource SectionPanel}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Название дела" Style="{StaticResource FieldLabel}" Margin="0,0,0,5" />
                                <TextBox Text="{Binding ThingName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" />

                                <TextBlock Text="Почему это важно" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding Why, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}"
                                         MinHeight="96"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Дата старта" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding StartDateText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Минут в день" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding TargetMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />
                                    </StackPanel>
                                </Grid>

                                <Button Content="Сохранить дело"
                                        Command="{Binding SavePlanCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Width="180"
                                        HorizontalAlignment="Left"
                                        Margin="0,20,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                        <TextBlock Text="Настройки" Style="{StaticResource NavText}" />
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="28">
                        <TextBlock Text="Настройки" Style="{StaticResource PageTitle}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <Border Style="{StaticResource SectionPanel}">
                                    <StackPanel>
                                        <TextBlock Text="Внешний вид" Style="{StaticResource SectionTitle}" />

                                        <TextBlock Text="Тема" Style="{StaticResource FieldLabel}" />
                                        <ComboBox SelectedValue="{Binding ThemeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  Style="{StaticResource Combo}">
                                            <ComboBoxItem Content="Как в Windows" Tag="System" />
                                            <ComboBoxItem Content="Темная" Tag="Dark" />
                                            <ComboBoxItem Content="Светлая" Tag="Light" />
                                        </ComboBox>

                                        <TextBlock Text="Акцент" Style="{StaticResource FieldLabel}" />
                                        <ComboBox SelectedValue="{Binding AccentColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  Style="{StaticResource Combo}">
                                            <ComboBoxItem Content="Бирюзовый" Tag="Teal" />
                                            <ComboBoxItem Content="Синий" Tag="Blue" />
                                            <ComboBoxItem Content="Зеленый" Tag="Green" />
                                            <ComboBoxItem Content="Фиолетовый" Tag="Violet" />
                                            <ComboBoxItem Content="Янтарный" Tag="Amber" />
                                            <ComboBoxItem Content="Розовый" Tag="Rose" />
                                        </ComboBox>

                                        <TextBlock Text="Плотность" Style="{StaticResource FieldLabel}" />
                                        <ComboBox SelectedValue="{Binding DensityMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Tag"
                                                  Style="{StaticResource Combo}">
                                            <ComboBoxItem Content="Компактная" Tag="Compact" />
                                            <ComboBoxItem Content="Обычная" Tag="Comfortable" />
                                            <ComboBoxItem Content="Свободная" Tag="Spacious" />
                                        </ComboBox>

                                        <TextBlock Text="Свой цвет акцента" Style="{StaticResource FieldLabel}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding CustomAccentHex, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource Input}" />
                                            <Border Grid.Column="2"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    BorderBrush="{DynamicResource LineBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4" />
                                        </Grid>

                                        <CheckBox Content="Использовать свой цвет фона"
                                                  IsChecked="{Binding UseCustomWindowColor}" />

                                        <TextBlock Text="Свой цвет фона" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding CustomWindowHex, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />

                                        <WrapPanel Margin="0,18,0,0">
                                            <Button Content="Применить цвета"
                                                    Command="{Binding ApplyCustomColorsCommand}"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Width="160"
                                                    Margin="0,0,8,8" />
                                            <Button Content="Сбросить цвета"
                                                    Command="{Binding ResetCustomColorsCommand}"
                                                    Style="{StaticResource GhostButton}"
                                                    Width="150"
                                                    Margin="0,0,8,8" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionPanel}" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Трей" Style="{StaticResource SectionTitle}" />
                                        <CheckBox Content="Сворачивать в трей"
                                                  IsChecked="{Binding MinimizeToTray}" />
                                        <CheckBox Content="Запускать вместе с Windows"
                                                  IsChecked="{Binding LaunchAtLogin}" />
                                        <Button Content="Открыть папку данных"
                                                Command="{Binding OpenDataFolderCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Width="210"
                                                HorizontalAlignment="Left"
                                                Margin="0,16,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource SectionPanel}">
                                    <StackPanel>
                                        <TextBlock Text="Напоминания" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="{Binding ReminderStatusText}"
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,6" />

                                        <CheckBox Content="Напоминания включены"
                                                  IsChecked="{Binding RemindersEnabled}" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Напоминать с" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ReminderStartText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Input}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Напоминать до" Style="{StaticResource FieldLabel}" />
                                                <TextBox Text="{Binding ReminderEndText, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Input}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Повторять каждые N минут" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding ReminderIntervalText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />

                                        <WrapPanel Margin="0,18,0,0">
                                            <Button Content="Сохранить"
                                                    Command="{Binding SaveSettingsCommand}"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Width="120"
                                                    Margin="0,0,8,8" />
                                            <Button Content="Отложить 60"
                                                    Command="{Binding Snooze60Command}"
                                                    Style="{StaticResource BaseButton}"
                                                    Width="130"
                                                    Margin="0,0,8,8" />
                                            <Button Content="Пропустить сегодня"
                                                    Command="{Binding SnoozeTodayCommand}"
                                                    Style="{StaticResource GhostButton}"
                                                    Width="170"
                                                    Margin="0,0,8,8" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionPanel}" Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Telegram" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="Привязка будет только к подтвержденному пользователю."
                                                   Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
