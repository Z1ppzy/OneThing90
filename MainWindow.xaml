<Window x:Class="OneThing90.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OneThing90"
        Width="1120"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0F1115">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171A20" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1F242C" />
        <SolidColorBrush x:Key="LineBrush" Color="#303640" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F1EA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A7ADB7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2DD4BF" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0F766E" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#101319" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#39414D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#2A3039" />
            <Setter Property="BorderBrush" Value="#3A4350" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#36404C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#20262F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#404855" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="#171A20"
                                BorderBrush="#303640"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#222832" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                                <Setter TargetName="TabRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DayCellBorder" TargetType="Border">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="#242A33" />
            <Setter Property="BorderBrush" Value="#353D49" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Complete">
                    <Setter Property="Background" Value="#16A34A" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Today">
                    <Setter Property="Background" Value="#B45309" />
                    <Setter Property="BorderBrush" Value="#FBBF24" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="PartialToday">
                    <Setter Property="Background" Value="#C2410C" />
                    <Setter Property="BorderBrush" Value="#FDBA74" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Partial">
                    <Setter Property="Background" Value="#7C3AED" />
                    <Setter Property="BorderBrush" Value="#C4B5FD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Missed">
                    <Setter Property="Background" Value="#3A2028" />
                    <Setter Property="BorderBrush" Value="#FB7185" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Future">
                    <Setter Property="Background" Value="#20242C" />
                    <Setter Property="BorderBrush" Value="#303640" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="OneThing90"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="34"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding PlanDayText}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#16211F"
                    BorderBrush="#245B54"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,9"
                    VerticalAlignment="Center">
                <TextBlock Text="90 минут - 90 дней - 1 дело"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Visibility="{Binding BannerVisibility}"
                Background="#221D14"
                BorderBrush="#7C4F13"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding BannerTitle}"
                               Foreground="#FFE8B0"
                               FontSize="15"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding BannerMessage}"
                               Foreground="#F8D99C"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Button Content="Начать 90"
                            Command="{Binding StartFocusCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Отложить 15"
                            Command="{Binding Snooze15Command}"
                            Style="{StaticResource BaseButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Скрыть"
                            Command="{Binding DismissBannerCommand}"
                            Style="{StaticResource GhostButton}" />
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="Сегодня">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Сегодня" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding ThingName}"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,16,0,0" />
                                <TextBlock Text="{Binding TodayStatusText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,20" />

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Сегодня" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding TodayMinutesText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Серия" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding StreakText}" Style="{StaticResource MetricValue}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding ReminderStatusText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,20" />

                                <Button Content="Начать 90-минутный блок"
                                        Command="{Binding StartFocusCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,0,10" />
                                <Button Content="Начать 15-минутное спасение"
                                        Command="{Binding StartRescueCommand}"
                                        Style="{StaticResource BaseButton}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Таймер фокуса" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding TimerDisplay}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="64"
                                           FontWeight="Bold"
                                           Margin="0,22,0,0" />
                                <TextBlock Text="{Binding TimerSubtitle}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           MinHeight="42" />
                                <ProgressBar Value="{Binding TimerProgress, Mode=OneWay}"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="10"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             Background="#262C35"
                                             Margin="0,22,0,20" />
                                <WrapPanel>
                                    <Button Content="{Binding PauseButtonText}"
                                            Command="{Binding PauseResumeCommand}"
                                            Style="{StaticResource BaseButton}"
                                            Width="132"
                                            Margin="0,0,8,8" />
                                    <Button Content="Записать сейчас"
                                            Command="{Binding FinishCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Width="156"
                                            Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Путь 90 дней">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Путь 90 дней" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding Why}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,18" />

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Закрыто" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding DaysCompletedText}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Осталось" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding DaysRemainingText}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Прогресс" Style="{StaticResource MetricLabel}" />
                                    <TextBlock Text="{Binding PlanProgress, StringFormat={}{0:0}%}" Style="{StaticResource MetricValue}" />
                                </StackPanel>
                            </Grid>

                            <ProgressBar Value="{Binding PlanProgress, Mode=OneWay}"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="10"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         Background="#262C35"
                                         Margin="0,0,0,22" />

                            <ItemsControl ItemsSource="{Binding Days}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DayCellBorder}"
                                                ToolTip="{Binding ToolTip}">
                                            <TextBlock Text="{Binding Number}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <WrapPanel Margin="0,20,0,0">
                                <TextBlock Text="Зеленый - закрыто"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,0,18,0" />
                                <TextBlock Text="Желтый - сегодня"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,0,18,0" />
                                <TextBlock Text="Розовый - пропуск"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Дело">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                    <Border Style="{StaticResource Card}" MaxWidth="720" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Главное дело" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Одна цель, которую приложение будет защищать от простоя."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />

                            <TextBlock Text="Название дела" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ThingName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" />

                            <TextBlock Text="Почему это важно" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Why, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}"
                                     MinHeight="96"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Дата старта" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding StartDateText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Минут в день" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding TargetMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                            </Grid>

                            <Button Content="Сохранить дело"
                                    Command="{Binding SavePlanCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="180"
                                    HorizontalAlignment="Left"
                                    Margin="0,20,0,0" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Настройки">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Напоминания" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding ReminderStatusText}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,14" />

                                <CheckBox Content="Напоминания включены"
                                          IsChecked="{Binding RemindersEnabled}"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,8,0,0" />
                                <CheckBox Content="Сворачивать в трей"
                                          IsChecked="{Binding MinimizeToTray}"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,8,0,0" />
                                <CheckBox Content="Запускать вместе с Windows"
                                          IsChecked="{Binding LaunchAtLogin}"
                                          Foreground="{StaticResource TextBrush}"
                                          Margin="0,8,0,0" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Напоминать с" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding ReminderStartText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Напоминать до" Style="{StaticResource FieldLabel}" />
                                        <TextBox Text="{Binding ReminderEndText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource Input}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Повторять каждые N минут" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding ReminderIntervalText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource Input}" />

                                <WrapPanel Margin="0,20,0,0">
                                    <Button Content="Сохранить"
                                            Command="{Binding SaveSettingsCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Width="120"
                                            Margin="0,0,8,8" />
                                    <Button Content="Отложить 60"
                                            Command="{Binding Snooze60Command}"
                                            Style="{StaticResource BaseButton}"
                                            Width="130"
                                            Margin="0,0,8,8" />
                                    <Button Content="Пропустить сегодня"
                                            Command="{Binding SnoozeTodayCommand}"
                                            Style="{StaticResource GhostButton}"
                                            Width="170"
                                            Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Трей и данные" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Если включено сворачивание в трей, крестик не закрывает приложение: оно продолжает следить за вечерним окном напоминаний."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,18" />

                                <TextBlock Text="В трее доступны: открыть окно, начать 90 минут, отложить на 30 минут и выйти."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,18" />

                                <Button Content="Открыть папку данных"
                                        Command="{Binding OpenDataFolderCommand}"
                                        Style="{StaticResource GhostButton}"
                                        Width="210"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
