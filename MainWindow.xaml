<Window x:Class="OneThing90.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OneThing90"
        Width="1180"
        Height="780"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0F1115">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#171A20" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#1F242C" />
        <SolidColorBrush x:Key="LineBrush" Color="#303640" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F1EA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#A7ADB7" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2DD4BF" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0F766E" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>

        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#101319" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#39414D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#2A3039" />
            <Setter Property="BorderBrush" Value="#3A4350" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#36404C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#20262F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#404855" />
        </Style>

        <Style x:Key="DayCellBorder" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="#242A33" />
            <Setter Property="BorderBrush" Value="#353D49" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Complete">
                    <Setter Property="Background" Value="#16A34A" />
                    <Setter Property="BorderBrush" Value="#86EFAC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Today">
                    <Setter Property="Background" Value="#B45309" />
                    <Setter Property="BorderBrush" Value="#FBBF24" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="PartialToday">
                    <Setter Property="Background" Value="#C2410C" />
                    <Setter Property="BorderBrush" Value="#FDBA74" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Partial">
                    <Setter Property="Background" Value="#7C3AED" />
                    <Setter Property="BorderBrush" Value="#C4B5FD" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Missed">
                    <Setter Property="Background" Value="#3A2028" />
                    <Setter Property="BorderBrush" Value="#FB7185" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Future">
                    <Setter Property="Background" Value="#20242C" />
                    <Setter Property="BorderBrush" Value="#303640" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="OneThing90"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="34"
                           FontWeight="Bold" />
                <TextBlock Text="{Binding PlanDayText}"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1"
                    Background="#16211F"
                    BorderBrush="#245B54"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,9"
                    VerticalAlignment="Center">
                <TextBlock Text="90 minutes - 90 days - 1 thing"
                           Foreground="{StaticResource PrimaryBrush}"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Visibility="{Binding BannerVisibility}"
                Background="#221D14"
                BorderBrush="#7C4F13"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding BannerTitle}"
                               Foreground="#FFE8B0"
                               FontSize="15"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding BannerMessage}"
                               Foreground="#F8D99C"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="18,0,0,0">
                    <Button Content="Start 90"
                            Command="{Binding StartFocusCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Snooze 15"
                            Command="{Binding Snooze15Command}"
                            Style="{StaticResource BaseButton}"
                            Margin="0,0,8,0" />
                    <Button Content="Dismiss"
                            Command="{Binding DismissBannerCommand}"
                            Style="{StaticResource GhostButton}" />
                </WrapPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Today"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="22"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding ThingName}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,14,0,0" />
                            <TextBlock Text="{Binding TodayStatusText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,18" />

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Today"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding TodayMinutesText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="20"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Streak"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12" />
                                    <TextBlock Text="{Binding StreakText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="20"
                                               FontWeight="Bold" />
                                </StackPanel>
                            </Grid>

                            <Button Content="Start 90-minute block"
                                    Command="{Binding StartFocusCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,0,10" />
                            <Button Content="Start 15-minute rescue"
                                    Command="{Binding StartRescueCommand}"
                                    Style="{StaticResource BaseButton}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Focus Timer"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="22"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding TimerDisplay}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="58"
                                       FontWeight="Bold"
                                       Margin="0,18,0,0" />
                            <TextBlock Text="{Binding TimerSubtitle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       MinHeight="38" />
                            <ProgressBar Value="{Binding TimerProgress, Mode=OneWay}"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="10"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         Background="#262C35"
                                         Margin="0,18,0,18" />
                            <WrapPanel>
                                <Button Content="{Binding PauseButtonText}"
                                        Command="{Binding PauseResumeCommand}"
                                        Style="{StaticResource BaseButton}"
                                        Width="116"
                                        Margin="0,0,8,8" />
                                <Button Content="Log now"
                                        Command="{Binding FinishCommand}"
                                        Style="{StaticResource GhostButton}"
                                        Width="116"
                                        Margin="0,0,8,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Text="90-Day Path"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding Why}"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,18" />

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Completed"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding DaysCompletedText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Remaining"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding DaysRemainingText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Progress"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="12" />
                                <TextBlock Text="{Binding PlanProgress, StringFormat={}{0:0}%}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="22"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Grid>

                        <ProgressBar Value="{Binding PlanProgress, Mode=OneWay}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="10"
                                     Foreground="{StaticResource PrimaryBrush}"
                                     Background="#262C35"
                                     Margin="0,0,0,18" />

                        <ItemsControl ItemsSource="{Binding Days}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DayCellBorder}"
                                            ToolTip="{Binding ToolTip}">
                                        <TextBlock Text="{Binding Number}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <WrapPanel Margin="0,18,0,0">
                            <TextBlock Text="Green complete"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,16,0" />
                            <TextBlock Text="Amber today"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,16,0" />
                            <TextBlock Text="Rose missed"
                                       Foreground="{StaticResource MutedTextBrush}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="Plan"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="22"
                                       FontWeight="Bold" />

                            <TextBlock Text="One thing" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ThingName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" />

                            <TextBlock Text="Reason" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding Why, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}"
                                     MinHeight="74"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Start date" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding StartDateText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Minutes" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding TargetMinutesText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                            </Grid>

                            <Button Content="Save plan"
                                    Command="{Binding SavePlanCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Nudges"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="22"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding ReminderStatusText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,12" />

                            <CheckBox Content="Reminders enabled"
                                      IsChecked="{Binding RemindersEnabled}"
                                      Foreground="{StaticResource TextBrush}"
                                      Margin="0,8,0,0" />
                            <CheckBox Content="Minimize to tray"
                                      IsChecked="{Binding MinimizeToTray}"
                                      Foreground="{StaticResource TextBrush}"
                                      Margin="0,8,0,0" />
                            <CheckBox Content="Launch with Windows"
                                      IsChecked="{Binding LaunchAtLogin}"
                                      Foreground="{StaticResource TextBrush}"
                                      Margin="0,8,0,0" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="From" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ReminderStartText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Until" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding ReminderEndText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource Input}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Repeat every minutes" Style="{StaticResource FieldLabel}" />
                            <TextBox Text="{Binding ReminderIntervalText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource Input}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="Save"
                                        Command="{Binding SaveSettingsCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Width="94"
                                        Margin="0,0,8,8" />
                                <Button Content="Snooze 60"
                                        Command="{Binding Snooze60Command}"
                                        Style="{StaticResource BaseButton}"
                                        Width="104"
                                        Margin="0,0,8,8" />
                                <Button Content="Skip today"
                                        Command="{Binding SnoozeTodayCommand}"
                                        Style="{StaticResource GhostButton}"
                                        Width="104"
                                        Margin="0,0,8,8" />
                            </WrapPanel>

                            <Button Content="Open data folder"
                                    Command="{Binding OpenDataFolderCommand}"
                                    Style="{StaticResource GhostButton}"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
